local function removerESP()
    for _, obj in ipairs(espObjetos) do pcall(function() obj:Destroy() end) end
    espObjetos = {}
end

local function atualizarESP()
    if not espAuraAtivo and not espNameAtivo then 
        removerESP()
        return 
    end
    
    for i = #espObjetos, 1, -1 do
        local obj = espObjetos[i]
        if not obj or not obj.Parent then
            table.remove(espObjetos, i)
        end
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            if hrp then
                local hl = char:FindFirstChild("ESPAura")
                if espAuraAtivo then
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "ESPAura"
                        hl.FillTransparency = 0.6
                        hl.OutlineTransparency = 0
                        hl.Parent = char
                        table.insert(espObjetos, hl)
                    end
                    hl.FillColor = corEspAtual
                    hl.OutlineColor = corEspAtual
                else
                    if hl then hl:Destroy() end
                end
                
                local bb = hrp:FindFirstChild("ESPNameGui")
                if espNameAtivo then
                    local lbl
                    if not bb then
                        bb = Instance.new("BillboardGui")
                        bb.Name = "ESPNameGui"
                        bb.Size = UDim2.new(0, 200, 0, 50)
                        bb.AlwaysOnTop = true
                        bb.StudsOffset = Vector3.new(0, 3.5, 0)
                        bb.Parent = hrp
                        table.insert(espObjetos, bb)
                        
                        lbl = Instance.new("TextLabel", bb)
                        lbl.Size = UDim2.new(1, 0, 1, 0)
                        lbl.BackgroundTransparency = 1
                        lbl.Font = Enum.Font.SourceSansBold
                        lbl.TextSize = 14
                    else
                        lbl = bb:FindFirstChildOfClass("TextLabel")
                    end
                    
                    if lbl then
                        lbl.Text = p.DisplayName .. "\n(@" .. p.Name .. ")"
                        lbl.TextColor3 = corEspAtual
                    end
                else
                    if bb then bb:Destroy() end
                end
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    atualizarESP()
end)

