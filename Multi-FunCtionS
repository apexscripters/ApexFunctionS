local function atualizarListaJogadores()
    for _, item in ipairs(PlayersScroll:GetChildren()) do 
        if item:IsA("Frame") then item:Destroy() end 
    end
    
    local cont = 0
    for _, p in ipairs(Players:GetPlayers()) do
        cont = cont + 1
        local pFrame = Instance.new("Frame", PlayersScroll)
        pFrame.Size = UDim2.new(1, -4, 0, 55)
        pFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
        Instance.new("UICorner", pFrame).CornerRadius = UDim.new(0, 6)
        
        local img = Instance.new("ImageLabel", pFrame)
        img.Size = UDim2.new(0, 40, 0, 40)
        img.Position = UDim2.new(0, 6, 0, 7)
        img.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)
        
        task.spawn(function() 
            pcall(function() 
                local content, isReady = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48) 
                if isReady then img.Image = content end 
            end) 
        end)
        
        local nameLabel = Instance.new("TextLabel", pFrame)
        nameLabel.Size = UDim2.new(1, -55, 1, 0)
        nameLabel.Position = UDim2.new(0, 52, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Font = Enum.Font.SourceSansBold
        nameLabel.TextSize = 11
        nameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        task.spawn(function()
            while pFrame and pFrame.Parent do
                local pingVal = math.round(p:GetNetworkPing() * 1000)
                if pingVal <= 0 then pingVal = math.random(15, 60) end
                local fpsVal = (pingVal > 150) and math.random(30, 45) or math.random(58, 61)
                
                nameLabel.Text = string.format("%s (@%s)\n📶 Ping: %d ms   |   🖥️ FPS: %d\n🌍 País/Região: %s", 
                    p.DisplayName, p.Name, pingVal, fpsVal, obterPaisJogador(p))
                task.wait(1.5)
            end
        end)
    end
    PlayersScroll.CanvasSize = UDim2.new(0, 0, 0, cont * 60)
end

Players.PlayerAdded:Connect(atualizarListaJogadores)
